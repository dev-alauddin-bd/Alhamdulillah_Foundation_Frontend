    "rules": {
      "title": "Foundation Operations & Regulations",
      "subtitle": "Our Target & Objective",
      "operationsHeading": "Operational Rules",
      "operationsList": [
        "This is a leadership financial institution whose main work is to manage financial investments by dividing into small groups.",
        "Our goal is to achieve social development by combining manpower and financial strength.",
        "The final investment of each of our investment projects is 30,000/- to 150,000/- BDT.",
        "A committee of 4-8 people will be formed for each project, whose job will be to play an active role from purchasing products to selling them.",
        "Each shareholder has to deposit one thousand BDT every month for up to 12 months.",
        "40% of the project's profit will go to the active committee, 10% to the welfare fund, and 50% will be deposited in all shareholders' accounts.",
        "This institution will be run in compliance with Islamic rules. We will work to build a interest-free society."
      ],
      "cancelHeading": "Regarding Share Cancellation",
      "cancelList": [
        "In case of failure to comply with the rules, membership will be cancelled first by notice and subsequently based on 51% opinion.",
        "Depositing savings every month is mandatory. Failure for 3 consecutive months will result in cancellation of ownership.",
        "Membership will be cancelled if involved in anti-social activities.",
        "No shareholder can close their account before completing 6 months.",
        "If irregularities are found in project work, the authority can impose financial fines or cancel shares."
      ],
      "quoteText": "\"We will always be social and build ourselves as dedicated souls to solve all kinds of problems in society.\"",
      "inshallah": "InshaAllah"
    }
  },

